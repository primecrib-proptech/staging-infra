# Backup runner: same Postgres image as server so pg_dump version matches exactly.
# Server uses postgis/postgis:16-3.5; we add awscli + cron only.
FROM postgis/postgis:16-3.5

RUN apt-get update && apt-get install -y --no-install-recommends \
    awscli \
    cron \
    gzip \
    gnupg \
    && rm -rf /var/lib/apt/lists/*

RUN mkdir -p /var/backups/postgres /var/log && touch /var/log/pg_backup.log

COPY cron.backup /etc/cron.d/pg-backup
RUN chmod 0644 /etc/cron.d/pg-backup && \
    crontab /etc/cron.d/pg-backup

CMD ["cron", "-f"]
